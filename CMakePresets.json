        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "GUCHHO_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "ci",
      "displayName": "CI",
      "description": "CI build with strict warnings",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/ci",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
